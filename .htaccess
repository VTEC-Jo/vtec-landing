# ══════════════════════════════════════════════════════════════════════════════
# Apache Configuration: Security, Caching, Performance & SEO
# ══════════════════════════════════════════════════════════════════════════════

# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Enforce HTTPS (uncomment if on production with SSL)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove www prefix (if preferred, swap with next rule)
    # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    # RewriteRule ^(.*)$ http://%1/$1 [R=301,L]

    # Add www prefix (uncomment if preferred)
    # RewriteCond %{HTTP_HOST} !^www\. [NC]
    # RewriteCond %{HTTP_HOST} !^localhost [NC]
    # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]

    # Redirect old favicon references
    RewriteRule ^favicon\.svg$ assets/favicon-untitled-16.png [R=301,L]
</IfModule>

# ── Cache Control ────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # HTML: No caching or minimal cache (validate each time)
    ExpiresByType text/html "access plus 0 seconds"
    Header set Cache-Control "public, must-revalidate, max-age=0"

    # CSS & JavaScript: 1 year (cache-busted via query strings or versioning)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"

    # Images: 3 months
    ExpiresByType image/jpeg "access plus 3 months"
    ExpiresByType image/gif "access plus 3 months"
    ExpiresByType image/png "access plus 3 months"
    ExpiresByType image/webp "access plus 3 months"
    ExpiresByType image/svg+xml "access plus 3 months"
    ExpiresByType image/x-icon "access plus 3 months"

    # Fonts: 1 year
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"

    # Manifest & Data: 1 month
    ExpiresByType application/json "access plus 1 month"
    ExpiresByType application/ld+json "access plus 1 month"
    ExpiresByType application/xml "access plus 1 month"
    ExpiresByType text/xml "access plus 1 month"
</IfModule>

# ── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE font/ttf
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE application/font-woff
    AddOutputFilterByType DEFLATE application/font-woff2
</IfModule>

# ── Headers & Security ──────────────────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # XSS Protection (legacy; modern browsers use CSP)
    Header always set X-XSS-Protection "1; mode=block"

    # Prevent clickjacking
    Header always set X-Frame-Options "DENY"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Feature Policy / Permissions Policy
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # Add charset to HTML responses
    <FilesMatch "\.html$">
        Header set Content-Type "text/html; charset=utf-8"
    </FilesMatch>

    # HSTS (Strict-Transport-Security) — uncomment for HTTPS-only sites
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ── Prevent access to sensitive files ────────────────────────────────────────
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(env|env\..*|yml|yaml|git|htpasswd|htaccess)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Charset default ─────────────────────────────────────────────────────────
AddDefaultCharset utf-8
AddCharset utf-8 .html .css .js .xml .json .rss .atom .svg .woff .woff2

# ── MIME types ──────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
    AddType application/javascript js
    AddType application/json json
    AddType image/svg+xml svg svgz
    AddType application/manifest+json webmanifest
    AddType video/mp4 mp4
    AddType video/webm webm
    AddType font/woff2 woff2
    AddType text/plain txt
</IfModule>
